# ============================================================================
#  .env.example — SAO CHÉP file này thành .env.local rồi điền giá trị thật.
#  KHÔNG commit .env.local (đã nằm trong .gitignore).
# ============================================================================

# --- Google Service Account (truy cập Sheets, chỉ dùng ở server) ---
# Lấy từ file JSON key khi tạo Service Account trên Google Cloud (xem README).
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# ⚠️ Dán TOÀN BỘ private key trong DẤU NGOÁC KÉP, một dòng, giữ nguyên "\n".
#    Ví dụ: GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# --- Google Spreadsheet ---
# ID nằm trong URL: https://docs.google.com/spreadsheets/d/<SPREADSHEET_ID>/edit
SPREADSHEET_ID=

# --- Auth.js (NextAuth v5) ---
# Sinh secret bằng: npx auth secret   (hoặc: openssl rand -base64 32)
AUTH_SECRET=
# OAuth Client ID / Secret từ Google Cloud > APIs & Services > Credentials
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# --- Allowlist đăng nhập ---
# Danh sách email được phép, ngăn cách bằng dấu phẩy. Ở MVP thường chỉ 1 email planner.
# Ví dụ: ALLOWED_EMAILS=planner@congty.com,admin@congty.com
ALLOWED_EMAILS=
